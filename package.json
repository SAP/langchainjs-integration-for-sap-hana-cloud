{
  "name": "@sap/hana-langchain",
  "version": "1.1.0",
  "description": "Integrates LangChain.js with SAP HANA Cloud to make use of vector search, knowledge graph, and further in-database capabilities as part of LLM-driven applications.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git@github.com:SAP/langchainjs-integration-for-sap-hana-cloud.git"
  },
  "homepage": "https://github.com/SAP/langchainjs-integration-for-sap-hana-cloud",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint:eslint": "NODE_OPTIONS=--max-old-space-size=4096 eslint --cache --ext .ts,.js src/",
    "lint:eslint:tests": "NODE_OPTIONS=--max-old-space-size=4096 eslint --cache --ext .ts,.js tests/",
    "lint:eslint:examples": "NODE_OPTIONS=--max-old-space-size=4096 eslint --cache --ext .ts,.js examples/",
    "lint:dpdm": "dpdm --exit-code circular:1 --no-warning --no-tree src/*.ts src/**/*.ts",
    "lint:dpdm:tests": "dpdm --exit-code circular:1 --no-warning --no-tree tests/**/*.ts",
    "lint:dpdm:examples": "dpdm --exit-code circular:1 --no-warning --no-tree examples/**/*.ts",
    "lint": "pnpm lint:eslint && pnpm lint:dpdm",
    "lint:fix": "pnpm lint:eslint --fix && pnpm lint:dpdm",
    "lint:tests": "pnpm lint:eslint:tests && pnpm lint:dpdm:tests",
    "lint:examples": "pnpm lint:eslint:examples && pnpm lint:dpdm:examples",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:int": "vitest run --mode int",
    "format": "prettier --config .prettierrc --write \"src\"",
    "format:check": "prettier --config .prettierrc --check \"src\"",
    "format:tests": "prettier --config .prettierrc --write \"tests\"",
    "format:tests:check": "prettier --config .prettierrc --check \"tests\"",
    "format:examples": "prettier --config .prettierrc --write \"examples\"",
    "format:examples:check": "prettier --config .prettierrc --check \"examples\""
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@sap/hana-client": "^2.28.19",
    "n3": "^1.26.0",
    "sparqljs": "^3.7.4"
  },
  "peerDependencies": {
    "@langchain/classic": "^1.0.31",
    "@langchain/core": "^1.1.40"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@eslint/js": "^9.39.4",
    "@langchain/core": "^1.1.40",
    "@langchain/scripts": "^0.1.3",
    "@langchain/textsplitters": "^1.0.1",
    "@types/n3": "^1.26.1",
    "@types/node": "^24.12.2",
    "@types/sparqljs": "^3.1.12",
    "dedent": "^1.7.2",
    "dotenv": "^17.4.2",
    "dpdm": "^3.15.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-instanceof": "^1.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "publint": "^0.3.18",
    "rdf-isomorphic": "^2.0.1",
    "rollup": "^4.60.2",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "unplugin-unused": "^0.5.7",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts",
        "default": "./dist/index.d.ts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/"
  ]
}
